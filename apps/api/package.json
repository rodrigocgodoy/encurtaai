{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "openapi": "tsx src/scripts/generate-openapi.ts",
    "auth:generate": "npx @better-auth/cli@latest generate --config ./src/utils/auth.ts --output ../../packages/database/prisma/schema.prisma --yes"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/swagger": "^9.6.1",
    "@repo/database": "workspace:*",
    "@scalar/fastify-api-reference": "^1.62.5",
    "better-auth": "^1.6.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.9.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
