# ─── Banco de dados (Postgres) ───────────────────────────────
# Em produção/dev use o Neon (https://neon.tech) — crie um projeto e cole a
# connection string aqui. NÃO precisa de Docker.
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── Better Auth ─────────────────────────────────────────────
# Gere um segredo com: openssl rand -base64 32
BETTER_AUTH_SECRET="troque-por-um-segredo-de-32-caracteres"
BETTER_AUTH_URL="http://localhost:3333"

# ─── URLs ────────────────────────────────────────────────────
APP_URL="http://localhost:5173"
PORT=3333
ENV="development"

# Exposto ao front (Vite). O api-client acrescenta /api/auth automaticamente.
VITE_API_URL="http://localhost:3333"
